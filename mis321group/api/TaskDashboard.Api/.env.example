# If set, used first (overrides Jaws).
ConnectionStrings__MySql=server=localhost;port=3306;database=taskdashboard;user=taskapp;password=changeme;
# Heroku: JawsDB sets JAWSDB_URL; leave ConnectionStrings__MySql empty there to use it automatically.
# JAWSDB_URL=mysql://user:pass@host:3306/dbname
OpenAI__ApiKey=
OpenAI__Model=gpt-4o-mini
OpenAI__BaseUrl=https://api.openai.com/v1
# Comma or semicolon separated. For GitHub Pages: https://YOURNAME.github.io
# Heroku: heroku config:set -a group14-321 Cors__AllowedOrigins="https://YOURNAME.github.io"
Cors__AllowedOrigins=
